{
  "hello": {
    "description": "Say hello",
    "help": "Prints a friendly greeting message to the console",
    "steps": [
      { "message": "Hello there!" },
      { "quit": 0 }
    ]
  },
  "racklist1": {
    "description": "List all tables in rack001 cloud database",
    "help": "Usage: larun racklist1\nLists all tables in the rack001 cloud database.",
    "steps": [
      { "var": "rack", "value": "rack001" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "cmd": "carack", "args": ["${rack}", "list-tables"] },
      { "quit": 0 }
    ]
  },
  "racktest1": {
    "description": "Query all rows from test1 table in rack001",
    "help": "Usage: larun racktest1\nQueries all data from the test1 table in rack001 cloud database.",
    "steps": [
      { "var": "rack", "value": "rack001" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "cmd": "carack", "args": ["${rack}", "get", "test1"] },
      { "quit": 0 }
    ]
  },
  "rackid1": {
    "description": "Query a row from test1 table by ID in rack001",
    "help": "Usage: larun rackid1 <id>\nQueries a row from the test1 table in rack001 by its ID.",
    "steps": [
      { "var": "rack", "value": "rack001" },
      { "var": "row_id", "value": "${1}", "default": "" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "if": { "var-defined": "row_id" },
        "do": [
          { "cmd": "carack", "args": ["${rack}", "get", "test1", "--filter", "id=${row_id}", "--limit", "1"] },
          { "quit": 0 }
        ]
      },
      { "message": "Error: id argument is required. Usage: larun rackid1 <id>" },
      { "quit": 1 }
    ]
  },
  "rackc1": {
    "description": "Fetch c1 value from test1 table by ID in rack001",
    "help": "Usage: larun rackc1 <id>\nFetches the c1 field from a row in test1 by its ID.",
    "steps": [
      { "var": "rack", "value": "rack001" },
      { "var": "row_id", "value": "${1}", "default": "" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "if": { "var-defined": "row_id" },
        "do": [
          { "var": "c1_val", "rack-get": { "rack": "${rack}", "table": "test1", "filter": "id=${row_id}", "field": "c1", "limit": 1 } },
          { "message": "${c1_val}" },
          { "quit": 0 }
        ]
      },
      { "message": "Error: id argument is required. Usage: larun rackc1 <id>" },
      { "quit": 1 }
    ]
  },
  "honeylist1": {
    "description": "List all tables in rackhoneylist cloud database",
    "help": "Usage: larun honeylist1\nLists all tables in the rackhoneylist cloud database.",
    "steps": [
      { "var": "rack", "value": "rackhoneylist" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "cmd": "carack", "args": ["${rack}", "list-tables"] },
      { "quit": 0 }
    ]
  },
  "honeyquery1": {
    "description": "Query all rows from project table in rackhoneylist",
    "help": "Usage: larun honeyquery1\nQueries all data from the project table in rackhoneylist.",
    "steps": [
      { "var": "rack", "value": "rackhoneylist" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "cmd": "carack", "args": ["${rack}", "get", "project"] },
      { "quit": 0 }
    ]
  },
  "honeyrender1": {
    "description": "Render all rows from project table in rackhoneylist",
    "help": "Usage: larun honeyrender1\nRenders all data from the project table in rackhoneylist.",
    "steps": [
      { "var": "rack", "value": "rackhoneylist" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "cmd": "carack", "args": ["${rack}", "render", "project"] },
      { "quit": 0 }
    ]
  },
  "email1": {
    "description": "Query email table from rackhoneylist, ordered by id asc",
    "help": "Usage: larun email1 [minid]\nQueries the email table with optional minimum ID filter, ordered by id ascending, limit 5.",
    "steps": [
      { "var": "rack", "value": "rackhoneylist" },
      { "var": "minid", "value": "${1}", "default": "" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "cmd": "carack", "args": ["${rack}", "render", "email", "--min-id", "${minid}", "--orderby", "id", "--order", "asc", "--limit", "5"] },
      { "quit": 0 }
    ]
  },
  "email2": {
    "description": "Query email table from rackhoneylist, ordered by id desc",
    "help": "Usage: larun email2 [minid]\nQueries the email table with optional minimum ID filter, ordered by id descending, limit 5.",
    "steps": [
      { "var": "rack", "value": "rackhoneylist" },
      { "var": "minid", "value": "${1}", "default": "" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "cmd": "carack", "args": ["${rack}", "render", "email", "--min-id", "${minid}", "--orderby", "id", "--order", "desc", "--limit", "5"] },
      { "quit": 0 }
    ]
  },
  "email3": {
    "description": "Query email table filtered by c1 exact match",
    "help": "Usage: larun email3 <c1_value>\nQueries email table where c1 matches exactly, ordered by id desc, limit 5.",
    "steps": [
      { "var": "rack", "value": "rackhoneylist" },
      { "var": "c1val", "value": "${1}", "default": "" },
      { "cmd": "carackcreate", "args": ["${rack}"], "silent": true },
      { "if": { "var-defined": "c1val" },
        "do": [
          { "cmd": "carack", "args": ["${rack}", "render", "email", "--filter", "c1=${c1val}", "--orderby", "id", "--order", "desc", "--limit", "5"] },
          { "quit": 0 }
        ]
      },
      { "message": "Error: c1 value is required. Usage: larun email3 <c1_value>" },
      { "quit": 1 }
    ]
  },
  "sync-hello": {
    "description": "Clone/pull a public test repo",
    "help": "Usage: larun sync-hello\nClones or pulls https://github.com/octocat/Hello-World.git to /tmp/hello-world",
    "steps": [
      { "var": "repo_url", "value": "https://github.com/octocat/Hello-World.git" },
      { "var": "target", "value": "/tmp/hello-world" },
      { "var": "git_dir", "value": "${target}/.git" },
      { "message": "Syncing ${repo_url} to ${target}..." },
      { "cmd": "lagit", "args": ["pull", "${repo_url}", "${target}"] },
      { "if": { "folder-exists": "${git_dir}" },
        "do": [
          { "message": "Success: Hello-World repo synced to ${target}" },
          { "quit": 0 }
        ],
        "else": [
          { "message": "Failed: ${git_dir} not found after sync" },
          { "quit": 1 }
        ]
      }
    ]
  },
  "installfirefox": {
    "description": "Install Firefox browser",
    "help": "Installs specified version of Firefox (115 or 128) to ${software-home}/firefox{VERSION}\nUsage: larun installfirefox [version]\n  version: Firefox version (115 or 128, default: 128)",
    "steps": [
      { "var": "version", "value": "${1}", "default": "128" },
      { "if": { "var-eq": {"key": "version", "value": "115"} },
        "do": [
          { "var": "ff_dir", "value": "${software-home}/firefox115" },
          { "var": "ff_url", "value": "https://www.dropbox.com/scl/fi/f0sph4i8p2a3iemrwgv93/firefox115.tar.xz?rlkey=aek7m9u9w2s67hsmskaa7u7d9&st=x3zwk8ab&dl=1" }
        ]
      },
      { "if": { "var-eq": {"key": "version", "value": "128"} },
        "do": [
          { "var": "ff_dir", "value": "${software-home}/firefox128" },
          { "var": "ff_url", "value": "https://www.dropbox.com/scl/fi/mwic29zlagvmlgzxjlgt0/firefox128.tar.xz?rlkey=hbcmrcmera8474kj2zu8pdzbg&st=gtwrak6w&dl=1" }
        ]
      },
      { "if": { "var-eq": {"key": "ff_url", "value": ""} },
        "do": [
          { "message": "Unsupported version: ${version}. Supported: 115, 128" },
          { "quit": 1 }
        ]
      },
      { "if": { "file-exists": "${ff_dir}/firefox" },
        "do": [
          { "message": "Firefox ${version} already installed at ${ff_dir}" },
          { "quit": 0 }
        ]
      },
      { "message": "Installing Firefox ${version}..." },
      { "cmd": "mkdir", "args": ["-p", "/tmp/firefox-install"] },
      { "cmd": "curl", "args": ["-fL", "-o", "/tmp/firefox-install/firefox${version}.tar.xz", "${ff_url}"] },
      { "cmd": "mkdir", "args": ["-p", "${ff_dir}"] },
      { "cmd": "tar", "args": ["-xJf", "/tmp/firefox-install/firefox${version}.tar.xz", "-C", "${ff_dir}", "--strip-components=1"] },
      { "cmd": "chown", "args": ["-R", "1000:1000", "${ff_dir}"] },
      { "cmd": "rm", "args": ["-rf", "/tmp/firefox-install"] },
      { "message": "" },
      { "message": "Firefox ${version} installed at ${ff_dir}." },
      { "quit": 0 }
    ]
  }
}
